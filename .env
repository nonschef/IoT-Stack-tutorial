# =============================================================================
# Umgebungsvariablen fuer docker-compose.yml
# WICHTIG: Alle Passwoerter und Tokens vor dem Einsatzaendern!
# Diese Datei NICHT oeffentlich teilen oder in Git committen.
# =============================================================================

# Allgemein
TZ=Europe/Berlin

# InfluxDB
INFLUXDB_USER=
INFLUXDB_PASSWORD=
INFLUXDB_ORG=
INFLUXDB_BUCKET=
INFLUXDB_ADMIN_TOKEN=

# Postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Grafana
GRAFANA_USER=
GRAFANA_PASSWORD=

# Flightradar24 (eigenen Sharing-Key von flightradar24.com/share-your-data eintragen)
FR24KEY=

# ultrafeeder / ADS-B Standort (fuer Reichweiten-Berechnung & Live-Karte)
# Koordinaten als Dezimalgrad, Hoehe in Metern  ueber Meeresspiegel
FEEDER_LAT=
FEEDER_LON=
FEEDER_ALT=

# MariaDB
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=

# PieHole
PIHOLE_WEB_PASSWORD=
