<?xml version='1.0' encoding='UTF-8'?>

<!DOCTYPE properties SYSTEM 'http://java.sun.com/dtd/properties.dtd'>

<!--
  Traccar Konfiguration
  Datenbankverbindung zu MariaDB: mariadb, Datenbank: traccar
  Passwörter müssen mit den Werten in der .env Datei übereinstimmen.
-->

<properties>

  <!-- =========================================================
       Datenbankverbindung (MariaDB / traccar)
       ========================================================= -->
  <entry key='database.driver'>com.mysql.cj.jdbc.Driver</entry>
  <entry key='database.url'>jdbc:mysql://mariadb:3306/traccar?serverTimezone=UTC&amp;allowPublicKeyRetrieval=true&amp;useSSL=false</entry>
  <entry key='database.user'>MARIADB_USER_HIER_EINTRAGEN</entry>
  <entry key='database.password'>MARIADB_PASSWORT_HIER_EINTRAGEN</entry>

  <!-- =========================================================
       Web-Server
       ========================================================= -->
  <entry key='web.enable'>true</entry>
  <entry key='web.port'>8082</entry>
  <!-- Nur localhost erlauben und per Reverse Proxy (nginx/Traefik) exponieren,
       oder auf 0.0.0.0 belassen, wenn direkter Zugriff gewünscht ist: -->
  <entry key='web.address'>0.0.0.0</entry>

  <!-- =========================================================
       Protokolle / Tracking-Ports
       Jedes Gerät nutzt ein eigenes Protokoll auf einem eigenen Port.
       Ports, die du nicht brauchst, können auskommentiert bleiben.
       ========================================================= -->

  <!-- OsmAnd (Standard, für Android/iOS Traccar-Client App) -->
  <entry key='osmand.port'>5055</entry>

  <!-- Teltonika (FMxxxx, TST100, ...) -->
  <!-- <entry key='teltonika.port'>5027</entry> -->

  <!-- Wialon IPS -->
  <!-- <entry key='wialon.port'>5006</entry> -->

  <!-- GT06 / concox (viele günstige China-Tracker) -->
  <!-- <entry key='gt06.port'>5023</entry> -->

  <!-- Meitrack -->
  <!-- <entry key='meitrack.port'>5020</entry> -->

  <!-- TK103 / GPS103 -->
  <!-- <entry key='gps103.port'>5001</entry> -->

  <!-- =========================================================
       Logging
       ========================================================= -->
  <entry key='logger.level'>warning</entry>
  <entry key='logger.file'>/opt/traccar/logs/tracker-server.log</entry>

</properties>
